# Database driver: "sqlite" (dev) or "sqlserver" (prod)
DB_DRIVER=sqlite

# Connection string
# SQLite (default): ./cmms.db
# SQL Server: sqlserver://user:password@server.database.windows.net:1433?database=cmms&encrypt=true&TrustServerCertificate=false
DB_CONNECTION_STRING=./cmms.db

# CORS origin (Azure Static Web Apps URL)
CORS_ORIGIN=https://your-app.azurestaticapps.net

# Server port
PORT=8080

# Seed database on startup (set to true only on first run)
SEED_ON_START=true
